# ============================================================
# EuroCure — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API

# Public URL — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon/public key — safe to expose in browser (RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — NEVER expose in browser or commit to git
# Used only in server-side API routes and server components
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Email (Resend) ────────────────────────────────────────────
# Get from: resend.com → API Keys
# Leave blank in development — bookings still save; emails won't send.

RESEND_API_KEY=re_your_resend_api_key_here

# Verified sender email (domain must be verified in Resend)
EMAIL_FROM=reservations@eurocure.clinic

# ── Application ───────────────────────────────────────────────
# Your deployment URL — used in admin notification emails
# Development: http://localhost:3000
# Production: https://your-project.vercel.app (or your custom domain)

APP_BASE_URL=http://localhost:3000

# ── Cron (optional — needed for automated reminders) ─────────
# Any random string, 32+ characters
# Used to authenticate calls to /api/cron/reminders
# Generate with: openssl rand -hex 32

CRON_SECRET=replace_with_a_random_secret_string

# ── WhatsApp (placeholder — not active yet) ───────────────────
# Will be used when WhatsApp Business API integration is implemented
WHATSAPP_PROVIDER_PLACEHOLDER_KEY=placeholder
